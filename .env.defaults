# Slack security config
CLIENT_SIGNING_SECRET=your-signing-secret-here

# Single-team Slack config
BOT_TOKEN=xoxb-your-bot-token-here

# Bolt Socket Mode config
SLACK_APP_TOKEN=xapp-your-app-token-here

# Plugin loading — comma-separated plugins to disable (deny-list).
# Leave unset/empty to load all plugins. Example: DISABLED_PLUGINS=add-prompt
DISABLED_PLUGINS=